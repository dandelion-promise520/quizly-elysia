{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.mjs"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
