{
  "name": "quizly",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.14",
  "description": "",
  "workspaces": [
    "apps/*"
  ],
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.12.1",
    "@eslint-react/eslint-plugin": "^1.24.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "lint-staged": "^15.3.0",
    "simple-git-hooks": "^2.11.1",
    "turbo": "^2.10.0",
    "typescript": "~6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run typecheck && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
